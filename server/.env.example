NODE_ENV=development
HOST=0.0.0.0
PORT=3000
QUESTION_CONTENT_DIR=
# 本地和测试使用标准 MySQL URL；云托管可仅提供 MYSQL_* 变量。
DATABASE_URL=mysql://quzijie:quzijie_dev_password@localhost:3306/quzijie_dev
TEST_DATABASE_URL=mysql://quzijie:quzijie_dev_password@localhost:3306/quzijie_test
MYSQL_ADDRESS=
MYSQL_USERNAME=
MYSQL_PASSWORD=
MYSQL_DATABASE=quzijie
DB_CONNECTION_LIMIT=5
QUIZIJIE_SEED_ON_EMPTY=true
JWT_ACCESS_SECRET=replace-with-at-least-32-characters-for-real-use
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
# 云托管生产环境使用 cloud；本地开发可使用 stub。
WECHAT_AUTH_MODE=stub
WECHAT_DEV_OPENID=dev-openid-quzijie
WECHAT_APP_ID=
WECHAT_APP_SECRET=
