NODE_ENV=development
HOST=0.0.0.0
PORT=3000
QUESTION_CONTENT_DIR=
# 本地和测试使用标准 MySQL URL；云托管可仅提供 MYSQL_* 变量。
DATABASE_URL=mysql://quzijie:quzijie_dev_password@localhost:3306/quzijie_dev
TEST_DATABASE_URL=mysql://quzijie:quzijie_dev_password@localhost:3306/quzijie_test
MYSQL_ADDRESS=
MYSQL_USERNAME=
MYSQL_PASSWORD=
MYSQL_DATABASE=quzijie
DB_CONNECTION_LIMIT=5
QUIZIJIE_SEED_ON_EMPTY=true
JWT_ACCESS_SECRET=replace-with-at-least-32-characters-for-real-use
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
# 云托管生产环境使用 cloud；本地开发可使用 stub。
WECHAT_AUTH_MODE=stub
WECHAT_DEV_OPENID=dev-openid-quzijie
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 题库管理后台默认关闭。生产启用时必须同时配置 COS，密钥请放云托管加密环境变量。
ADMIN_ENABLED=false
ADMIN_ENCRYPTION_KEY=
ADMIN_SESSION_TTL_HOURS=12
QUESTION_BANK_STORAGE=local
QUESTION_BANK_STORAGE_DIR=.question-bank-storage
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
# 可选：自定义 CDN/公有读域名；不填则使用 COS 默认域名。
COS_PUBLIC_BASE_URL=
QUESTION_BANK_MAX_SNAPSHOT_BYTES=268435456
