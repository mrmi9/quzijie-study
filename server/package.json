{
  "name": "quzijie-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "npm run build && node --test dist/tests/unit/*.test.js",
    "test:integration": "prisma migrate deploy --config prisma.test.config.ts && npm run build && node --test dist/tests/integration/*.test.js",
    "verify": "npm run typecheck && npm test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/scripts/import-questions.ts"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/pg": "^8.15.6",
    "prisma": "^7.8.0",
    "tsx": "^4.20.6",
    "typescript": "^7.0.2"
  }
}
