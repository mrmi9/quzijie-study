{
  "name": "quzijie-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "start:cloud": "node dist/src/scripts/cloudrun-bootstrap.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "npm run build && node --test dist/tests/unit/*.test.js",
    "test:integration": "tsx src/scripts/reset-integration-database.ts && prisma migrate deploy --config prisma.test.config.ts && npm run build && node --test dist/tests/integration/*.test.js",
    "verify": "npm run typecheck && npm test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:bootstrap-baseline": "tsx src/scripts/import-questions.ts",
    "db:bootstrap-baseline:compiled": "node dist/src/scripts/import-questions.js",
    "db:export-mock": "tsx src/scripts/export-mock-snapshot.ts",
    "admin:manage": "tsx src/scripts/manage-admin.ts",
    "admin:manage:compiled": "node dist/src/scripts/manage-admin.js",
    "admin:bootstrap-token": "tsx src/scripts/generate-admin-bootstrap-token.ts",
    "admin:bootstrap-token:compiled": "node dist/src/scripts/generate-admin-bootstrap-token.js",
    "storage:lifecycle": "tsx src/scripts/configure-cos-lifecycle.ts",
    "storage:lifecycle:compiled": "node dist/src/scripts/configure-cos-lifecycle.js",
    "storage:cleanup": "tsx src/scripts/cleanup-question-bank-storage.ts",
    "storage:cleanup:compiled": "node dist/src/scripts/cleanup-question-bank-storage.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^10.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cos-nodejs-sdk-v5": "^3.0.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "mariadb": "^3.4.5",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}
