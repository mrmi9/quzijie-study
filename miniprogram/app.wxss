page {
  min-height: 100%;
  background: #f4f7fb;
  color: #172033;
  font-size: 28rpx;
  box-sizing: border-box;
}

view,
text,
button,
scroll-view {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 0;
  padding-bottom: 0;
  line-height: 1.2;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(35, 55, 90, 0.08);
}

.primary-button,
.secondary-button,
.danger-button {
  height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-button {
  color: #ffffff;
  background: #2563eb;
}

.primary-button[disabled] {
  color: rgba(255, 255, 255, 0.8);
  background: #93b4f7;
}

.secondary-button {
  color: #2563eb;
  background: #eaf1ff;
}

.danger-button {
  color: #b42318;
  background: #feeceb;
}

.muted {
  color: #718096;
}

.empty-state,
.error-state,
.loading-state {
  padding: 96rpx 32rpx;
  text-align: center;
  color: #718096;
}

.section-title {
  margin: 36rpx 0 20rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  color: #31548a;
  background: #edf4ff;
  font-size: 24rpx;
}

.safe-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
