<view class="page-shell safe-bottom exam-page">
  <view wx:if="{{loading}}" class="loading-state">正在恢复试卷...</view>
  <view wx:elif="{{error}}" class="error-state"><text>{{error}}</text><button class="secondary-button error-action" bindtap="loadExam">重试</button></view>
  <block wx:elif="{{question}}">
    <view class="exam-toolbar card">
      <view><text class="question-index">第 {{currentIndex + 1}} / 40 题</text><text class="saved-state">{{saving ? '正在保存...' : '草稿已自动保存'}}</text></view>
      <text class="timer {{timerWarning ? 'timer-warning' : ''}}">{{remainingText}}</text>
    </view>

    <view class="progress-track"><view class="progress-value" style="width: {{(currentIndex + 1) * 2.5}}%;"></view></view>

    <view class="question-card card">
      <view class="question-meta"><text class="pill">{{question.subjectName}} · 单选题</text><text class="answered-pill">已答 {{answeredCount}} / 40</text></view>
      <text class="question-stem">{{question.stem}}</text>
      <scroll-view wx:if="{{question.code}}" class="code-block" scroll-x="true"><text selectable="true">{{question.code}}</text></scroll-view>
      <view wx:if="{{question.images.length}}" class="question-images">
        <view wx:for="{{question.images}}" wx:key="src" wx:for-item="imageItem"><image class="question-image" src="{{imageItem.src}}" mode="widthFix" data-src="{{imageItem.src}}" bindtap="previewImage"></image><text class="image-alt">{{imageItem.alt}}</text></view>
      </view>
    </view>

    <view class="option-list">
      <view class="option-card card {{item.selected ? 'option-selected' : ''}}" wx:for="{{question.options}}" wx:key="id" data-id="{{item.id}}" bindtap="selectOption">
        <view class="option-label">{{item.label}}</view><text class="option-text">{{item.text}}</text>
      </view>
    </view>

    <view class="exam-bottom-bar">
      <view class="bottom-meta">
        <text class="bottom-progress">已答 {{answeredCount}} / {{exam.totalCount}} 题</text>
        <text class="early-submit" bindtap="requestSubmit">提前交卷</text>
      </view>
      <view class="navigation-row">
        <button class="secondary-button nav-button" disabled="{{currentIndex === 0}}" bindtap="previousQuestion">上一题</button>
        <button class="card-button" bindtap="toggleCard">答题卡</button>
        <button wx:if="{{currentIndex !== exam.totalCount - 1}}" class="next-button" bindtap="nextQuestion">下一题</button>
        <button wx:else class="next-button finish-button" loading="{{submitting}}" bindtap="requestSubmit">检查并交卷</button>
      </view>
    </view>

    <view wx:if="{{showCard}}" class="card-mask" bindtap="toggleCard"></view>
    <view class="answer-sheet {{showCard ? 'sheet-open' : ''}}">
      <view class="sheet-head"><text class="sheet-title">答题卡</text><text class="sheet-close" bindtap="toggleCard">关闭</text></view>
      <text class="sheet-tip">蓝色为已答，灰色为未答；点击题号可跳转。</text>
      <view class="sheet-grid">
        <view class="sheet-item {{answers[item.id] ? 'sheet-answered' : ''}} {{currentIndex === index ? 'sheet-current' : ''}}" wx:for="{{exam.questions}}" wx:key="id" data-index="{{index}}" bindtap="goQuestion">{{index + 1}}</view>
      </view>
    </view>
  </block>
</view>
