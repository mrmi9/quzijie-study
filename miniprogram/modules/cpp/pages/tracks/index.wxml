<view class="page-shell safe-bottom">
  <block wx:if="{{module}}">
    <text class="top-title">{{module.name}}</text>
    <text class="top-subtitle">请选择本次学习方向。两个方向独立保存进度、错题与收藏。</text>
  </block>

  <view wx:if="{{loading}}" class="loading-state">正在加载学习方向...</view>
  <view wx:elif="{{error}}" class="error-state">
    <text>{{error}}</text>
    <button wx:if="{{module}}" class="secondary-button error-action" bindtap="loadTracks">重新加载</button>
  </view>
  <view wx:else class="track-list">
    <view class="track-card card" wx:for="{{tracks}}" wx:key="id" data-id="{{item.id}}" bindtap="openTrack">
      <view class="track-accent" style="background: {{item.color}};"></view>
      <view class="track-content">
        <view class="row-between">
          <text class="track-name">{{item.name}}</text>
          <text class="track-progress">{{item.progressPercent}}%</text>
        </view>
        <text class="track-description">{{item.description}}</text>
        <text class="track-meta">已学习 {{item.attemptedCount}} / {{item.totalQuestions}} 题 · 正确率 {{item.accuracy}}%</text>
        <view class="progress-track"><view class="progress-value" style="width: {{item.progressPercent}}%; background: {{item.color}};"></view></view>
      </view>
      <text class="track-arrow">›</text>
    </view>
  </view>
</view>
