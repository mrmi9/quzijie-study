@import "../../common.wxss";

.top-title,
.top-subtitle,
.track-name,
.track-description,
.track-meta {
  display: block;
}

.top-title { font-size: 42rpx; font-weight: 800; }
.top-subtitle { margin-top: 12rpx; color: #64748b; line-height: 1.6; }
.track-list { margin-top: 30rpx; }
.track-card { display: flex; align-items: stretch; margin-bottom: 24rpx; overflow: hidden; }
.track-accent { width: 12rpx; }
.track-content { flex: 1; padding: 30rpx 22rpx 30rpx 28rpx; }
.row-between { display: flex; justify-content: space-between; align-items: center; }
.track-name { font-size: 34rpx; font-weight: 800; }
.track-progress { color: #2563eb; font-size: 30rpx; font-weight: 800; }
.track-description { margin-top: 12rpx; color: #475569; }
.track-meta { margin-top: 16rpx; color: #718096; font-size: 23rpx; }
.track-arrow { align-self: center; padding-right: 24rpx; color: #94a3b8; font-size: 48rpx; }
.progress-track { height: 10rpx; margin-top: 22rpx; border-radius: 5rpx; background: #e2e8f0; overflow: hidden; }
.progress-value { height: 100%; border-radius: 5rpx; }
.error-action { margin-top: 24rpx; }
