.records-page { padding-top: 28rpx; }
.page-title, .page-subtitle, .stem, .answer, .explanation, .image-alt { display: block; }
.page-title { font-size: 44rpx; font-weight: 800; }
.page-subtitle { margin-top: 10rpx; color: #718096; line-height: 1.6; }
.filter-scroll { width: 100%; margin-top: 26rpx; white-space: nowrap; }
.filter-row { display: inline-flex; gap: 12rpx; }
.filter-chip { padding: 14rpx 22rpx; border-radius: 28rpx; color: #64748b; background: #e8edf5; }
.filter-chip.active { color: #fff; background: #2563eb; }
.mastery-row { display: flex; margin: 22rpx 0; padding: 7rpx; border-radius: 16rpx; background: #e8edf5; }
.mastery { flex: 1; padding: 14rpx 0; border-radius: 12rpx; text-align: center; color: #64748b; }
.mastery.active { color: #1d4ed8; background: #fff; font-weight: 700; }
.record-card { margin-bottom: 20rpx; padding: 26rpx; }
.record-head { display: flex; align-items: center; justify-content: space-between; }
.status { color: #d92d20; font-size: 23rpx; font-weight: 700; }
.status.mastered { color: #178f5b; }
.stem { margin-top: 18rpx; font-size: 29rpx; font-weight: 650; line-height: 1.6; }
.record-code { width: 100%; margin-top: 18rpx; padding: 20rpx; border-radius: 14rpx; color: #dbeafe; background: #152238; font-family: Consolas, monospace; white-space: pre; }
.record-images { margin-top: 18rpx; }
.record-image { width: 100%; border-radius: 14rpx; }
.image-alt { margin: 8rpx 0 16rpx; color: #64748b; font-size: 22rpx; }
.answer { margin-top: 18rpx; color: #1d4ed8; font-weight: 700; }
.explanation { margin-top: 10rpx; color: #475569; line-height: 1.65; }
.bottom-action { position: sticky; bottom: 0; margin: 24rpx -32rpx -32rpx; padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(244,247,251,.96); }
