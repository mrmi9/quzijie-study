.login-page {
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-card {
  width: 100%;
  padding: 56rpx 40rpx;
  text-align: center;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 34rpx;
  border-radius: 40rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #1d4ed8, #60a5fa);
  font-size: 34rpx;
  font-weight: 800;
}

.title,
.description {
  display: block;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.description {
  margin: 22rpx 0 32rpx;
  color: #718096;
  line-height: 1.7;
}

.mock-tip {
  margin-bottom: 32rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  color: #8a5a00;
  background: #fff6dc;
  font-size: 24rpx;
}

.privacy-consent {
  display: flex;
  justify-content: center;
  margin-top: 28rpx;
  color: #718096;
  font-size: 23rpx;
}

.privacy-link {
  color: #2563eb;
}
