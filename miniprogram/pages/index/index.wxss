.home-page {
  padding-top: 0;
}

.hero {
  margin: 0 -32rpx;
  padding: 76rpx 48rpx 64rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #1d4ed8, #3b82f6 60%, #60a5fa);
  border-radius: 0 0 48rpx 48rpx;
}

.hero-badge,
.hero-title,
.hero-subtitle {
  display: block;
}

.hero-badge {
  margin-bottom: 20rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

.hero-title {
  font-size: 60rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  margin-top: 18rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
}

.module-card {
  min-height: 240rpx;
  padding: 30rpx;
}

.module-disabled {
  opacity: 0.58;
}

.module-dot {
  width: 18rpx;
  height: 18rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
}

.module-name,
.module-subtitle,
.module-status {
  display: block;
}

.module-name {
  font-size: 32rpx;
  font-weight: 700;
}

.module-subtitle {
  min-height: 72rpx;
  margin-top: 12rpx;
  color: #718096;
  font-size: 24rpx;
  line-height: 1.5;
}

.module-status {
  margin-top: 18rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 600;
}
