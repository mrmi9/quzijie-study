.home-page {
  padding-top: 0;
}

.hero {
  margin: 0 -32rpx;
  padding: 76rpx 48rpx 64rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #1d4ed8, #3b82f6 60%, #60a5fa);
  border-radius: 0 0 48rpx 48rpx;
}

.hero-badge,
.hero-title,
.hero-subtitle {
  display: block;
}

.hero-badge {
  margin-bottom: 20rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

.hero-title {
  font-size: 60rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  margin-top: 18rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
}

.module-card {
  min-height: 240rpx;
  padding: 30rpx;
}

.module-dot {
  width: 18rpx;
  height: 18rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
}

.module-name,
.module-subtitle,
.module-status {
  display: block;
}

.module-name {
  font-size: 32rpx;
  font-weight: 700;
}

.module-subtitle {
  min-height: 72rpx;
  margin-top: 12rpx;
  color: #718096;
  font-size: 24rpx;
  line-height: 1.5;
}

.module-status {
  margin-top: 18rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 600;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}

.stat-card { padding: 24rpx; }
.stat-number, .stat-label, .resume-title, .resume-meta { display: block; }
.stat-number { color: #1d4ed8; font-size: 36rpx; font-weight: 800; }
.stat-label { margin-top: 6rpx; color: #718096; font-size: 23rpx; }

.resume-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 26rpx;
  border: 2rpx solid #bfdbfe;
}

.exam-resume { border-color: #f5b8d5; }
.resume-title { font-weight: 700; }
.resume-meta { margin-top: 7rpx; color: #718096; font-size: 23rpx; }
.resume-link { color: #2563eb; font-weight: 700; }

.module-progress {
  height: 8rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 4rpx;
  background: #e8edf5;
}
.module-progress-value { height: 100%; border-radius: 4rpx; }
.retry-button { width: 220rpx; margin-top: 24rpx; }
