.privacy-card {
  padding: 36rpx 32rpx;
}

.privacy-title,
.privacy-updated,
.privacy-heading,
.privacy-text,
.privacy-note {
  display: block;
}

.privacy-title {
  font-size: 40rpx;
  font-weight: 800;
}

.privacy-updated {
  margin-top: 10rpx;
  color: #94a3b8;
  font-size: 23rpx;
}

.privacy-heading {
  margin-top: 34rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.privacy-text,
.privacy-note {
  margin-top: 12rpx;
  color: #526179;
  line-height: 1.8;
}

.privacy-note {
  margin-top: 38rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #eef4ff;
  font-size: 24rpx;
}
