.achievements-page { padding-top: 26rpx; }
.achievement-summary { padding: 30rpx; background: linear-gradient(135deg, #1d4ed8, #7c3aed); }
.summary-kicker, .summary-count, .summary-note, .achievement-title, .achievement-rarity, .achievement-description, .progress-text { display: block; }
.summary-kicker { color: #bfdbfe; font-size: 23rpx; font-weight: 700; letter-spacing: 3rpx; }
.summary-count { margin-top: 8rpx; color: white; font-size: 40rpx; font-weight: 900; }
.summary-track, .progress-track { overflow: hidden; background: rgba(255,255,255,.22); border-radius: 999rpx; }
.summary-track { height: 14rpx; margin-top: 22rpx; }
.summary-progress, .progress-value { height: 100%; background: linear-gradient(90deg, #fde68a, #f59e0b); border-radius: inherit; }
.summary-note { margin-top: 16rpx; color: #dbeafe; font-size: 22rpx; }
.achievement-state { margin-top: 24rpx; padding: 34rpx; color: #64748b; text-align: center; }
.achievement-error { color: #b42318; }
.retry-button { width: 180rpx; margin-top: 18rpx; color: #2563eb; background: #eaf1ff; }
.achievement-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18rpx; margin-top: 24rpx; }
.achievement-card { position: relative; min-width: 0; padding: 24rpx 20rpx 20rpx; text-align: center; border: 2rpx solid #dbeafe; }
.rarity-rare { border-color: #7dd3fc; background: linear-gradient(150deg, #ffffff, #f0f9ff); }
.rarity-epic { border-color: #c4b5fd; background: linear-gradient(150deg, #ffffff, #faf5ff); }
.rarity-legendary { border-color: #fbbf24; background: linear-gradient(150deg, #fffbeb, #fff7ed); }
.achievement-equipped { box-shadow: 0 0 0 4rpx rgba(124,58,237,.12), 0 14rpx 28rpx rgba(124,58,237,.12); }
.achievement-locked { filter: grayscale(.85); opacity: .66; }
.equipped-mark { position: absolute; top: 14rpx; right: 14rpx; z-index: 2; padding: 6rpx 12rpx; color: white; background: #7c3aed; font-size: 18rpx; border-radius: 999rpx; }
.badge-wrap { position: relative; width: 150rpx; height: 150rpx; margin: 0 auto; }
.achievement-badge { width: 100%; height: 100%; filter: drop-shadow(0 10rpx 12rpx rgba(37,99,235,.18)); }
.lock-mark { position: absolute; right: 5rpx; bottom: 4rpx; display: flex; align-items: center; justify-content: center; width: 48rpx; height: 48rpx; color: white; background: #64748b; font-size: 20rpx; border-radius: 50%; }
.achievement-title { margin-top: 8rpx; color: #0f172a; font-size: 29rpx; font-weight: 900; }
.achievement-rarity { margin-top: 5rpx; color: #7c3aed; font-size: 20rpx; font-weight: 700; }
.achievement-description { min-height: 66rpx; margin-top: 10rpx; color: #64748b; font-size: 21rpx; line-height: 1.5; }
.progress-track { height: 10rpx; margin-top: 16rpx; background: #e2e8f0; }
.progress-value { background: linear-gradient(90deg, #60a5fa, #7c3aed); }
.progress-text { margin-top: 7rpx; color: #64748b; font-size: 20rpx; }
.equip-button { height: 62rpx; margin-top: 14rpx; color: white; background: #2563eb; font-size: 22rpx; line-height: 62rpx; border-radius: 14rpx; }
.unequip-button { color: #64748b; background: #e2e8f0; }
